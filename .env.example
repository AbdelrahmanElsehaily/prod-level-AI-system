# Copy this file to .env and fill in values for local development.
# .env is in .gitignore — never commit it.
# This file (.env.example) is safe to commit: no real values, just the variable names.

# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/chatapi

# --- Cache ---
REDIS_URL=redis://localhost:6379

# --- AI provider: Ollama ---
# Ollama must be running locally before starting the app.
# Install: https://ollama.com
# Start:   ollama serve
# Pull a model first: ollama pull llama3.2
#
# Base URL where Ollama listens:
#   Local dev:  http://localhost:11434   (default, no need to set)
#   Docker:     http://host.docker.internal:11434
OLLAMA_BASE_URL=http://localhost:11434

# Which model to use — must be pulled with `ollama pull <model>` first.
# Options: llama3.2, mistral, gemma3, phi4, qwen2.5, etc.
# See all available models: https://ollama.com/library
OLLAMA_MODEL=llama3.2

# --- Observability (optional) ---
# Leave blank in local dev — these services are only needed in production.
SENTRY_DSN=
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=

# --- Environment ---
# Controls log format: "development" = pretty console, "production" = JSON
ENVIRONMENT=development
